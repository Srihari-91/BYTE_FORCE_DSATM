{
  "manifest_version": 3,
  "name": "TruthCart — Truth Verification Engine",
  "version": "1.0.0",
  "description": "Real-time marketing truth verification for tech products. Detects deception, translates specs, and shows real-world performance insights.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.in/*",
    "https://*.flipkart.com/*",
    "https://*.bestbuy.com/*",
    "https://*.walmart.com/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.in/*",
        "https://*.flipkart.com/*",
        "https://*.bestbuy.com/*",
        "https://*.walmart.com/*"
      ],
      "js": [
        "utils/debounce.js",
        "utils/logger.js",
        "utils/dom.js",
        "content/detector.js",
        "content/observer.js",
        "content/extractor/amazon.js",
        "content/extractor/flipkart.js",
        "content/extractor/generic.js",
        "content/extractor/index.js",
        "content/normalizer.js",
        "content/fingerprint.js",
        "content/confidence.js",
        "content/cache.js",
        "content/api.js",
        "content/chatbot.js",
        "content/overlay/components.js",
        "content/overlay/overlay.js",
        "content/content.js"
      ],
      "css": ["content/overlay/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/overlay/styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
